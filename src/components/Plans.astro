---
import { Icon } from "astro-icon/components";

interface Plan {
  name: string;
  description: string;
  features: string[];
  ctaText: string;
  ctaHref: string;
  isPopular?: boolean;
  isPrimary?: boolean;
  isPersonalized?: boolean;
}

const plans: Plan[] = [
  {
    name: "PÁGINA WEB",
    description: "Ideal para emprendedores y startups",
    features: [
      "Diseño moderno y adaptable",
      "Secciones personalizadas",
      "Formulario de contacto",
      "Optimización SEO avanzada",
      "Entrega en 48 horas",
    ],
    ctaText: "Comenzar",
    ctaHref:
      "https://wa.me/5492615990250?text=¡Hola!%20Me%20gustaría%20saber%20más%20sobre%20el%20desarrollo%20de%20una%20página%20web.",
    isPopular: false,
    isPrimary: false,
    isPersonalized: false,
  },
  {
    name: "SISTEMA DE GESTIÓN",
    description: "Para negocios en crecimiento",
    features: [
      "Control de inventario y movimientos de stock",
      "Alertas de productos con stock bajo",
      "Registro de ventas, ingresos y gastos",
      "Reportes de ventas, stock y rendimiento",
      "Generación de presupuestos, comprobantes y documentos",
      "Mantenimiento, actualizaciones y soporte técnico",
    ],
    ctaText: "Comenzar",
    ctaHref:
      "https://wa.me/5492615990250?text=¡Hola!%20Me%20interesaría%20obtener%20más%20información%20sobre%20un%20sistema%20de%20gestión.",
    isPopular: true,
    isPrimary: true,
    isPersonalized: false,
  },
  {
    name: "E-COMMERCE",
    description: "Vendé tus productos las 24 horas, desde cualquier lugar",
    features: [
      "Catálogo de productos y categorías",
      "Carrito de compras y gestión de pedidos",
      "Integración con Mercado Pago",
      "Control de stock en tiempo real",
      "Gestión de clientes y ventas",
      "Cupones, promociones y descuentos",
      "Panel autogestionable",
      "Reportes de ventas y productos más vendidos",
      "Diseño adaptable a celulares y computadoras",
      "Mantenimiento y soporte técnico",
    ],
    ctaText: "Comenzar",
    ctaHref:
      "https://wa.me/5492615990250?text=¡Hola!%20Quiero%20consultar%20sobre%20el%20desarrollo%20de%20un%20e-commerce.",
    isPopular: false,
    isPrimary: false,
    isPersonalized: false,
  },
  {
    name: "SISTEMA PERSONALIZADO",
    description: "Nos adaptamos a tu necesidad",
    features: [
      "E-commerce",
      "Turneros y reservas automatizadas",
      "Plataformas educativas",
      "Generadores de documentos",
      "Cotizadores automáticos",
      "Portales de autogestión de clientes",
    ],
    ctaText: "Quiero un presupuesto",
    ctaHref:
      "https://wa.me/5492615990250?text=¡Hola!%20Me%20gustaría%20cotizar%20un%20sistema%20personalizado%20a%20medida.",
    isPopular: false,
    isPrimary: false,
    isPersonalized: true,
  },
];
---

<section class="py-24 bg-slate-950 relative overflow-hidden" id="planes">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <!-- Subtle grid texture for depth -->
    <div
      class="absolute inset-0 opacity-[0.035]"
      style="background-image: linear-gradient(to right, white 1px, transparent 1px), linear-gradient(to bottom, white 1px, transparent 1px); background-size: 64px 64px;"
    >
    </div>
    <div
      class="absolute top-[10%] right-[-5%] w-[35%] h-[50%] bg-cyan-600/15 rounded-full blur-[140px]"
    >
    </div>
    <div
      class="absolute bottom-[5%] left-[-10%] w-[30%] h-[40%] bg-indigo-600/15 rounded-full blur-[120px]"
    >
    </div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-7xl mx-auto">
      <!-- Header -->
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span
          class="inline-block mb-5 px-4 py-1.5 rounded-full border border-white/10 bg-white/5 text-xs font-medium uppercase tracking-[0.2em] text-cyan-300/90"
        >
          Planes
        </span>
        <h2
          class="text-4xl md:text-5xl font-normal font-display text-white mb-6 tracking-tight"
        >
          Planes que <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-200 to-indigo-200"
            >escalan contigo</span
          >
        </h2>
        <p class="text-lg text-slate-400">
          Elige el plan perfecto para tu negocio. Sin costos ocultos.
        </p>
      </div>

      <!-- Plans Grid -->
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch"
      >
        {
          plans.map((plan) => (
            <div
              class={`relative group rounded-3xl p-px transition-all duration-500 hover:-translate-y-2 ${
                plan.isPrimary
                  ? "bg-gradient-to-b from-cyan-400/70 via-cyan-500/25 to-transparent lg:-mt-4 lg:mb-4 shadow-2xl shadow-cyan-500/20"
                  : plan.isPersonalized
                    ? "bg-gradient-to-b from-indigo-400/40 via-violet-500/15 to-transparent hover:from-indigo-400/60"
                    : "bg-gradient-to-b from-white/20 to-white/[0.04] hover:from-white/35"
              }`}
            >
              {/* Popular Badge */}
              {plan.isPopular && (
                <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 z-20">
                  <div class="px-4 py-1.5 rounded-full bg-gradient-to-r from-cyan-400 to-cyan-500 text-slate-950 text-xs font-bold uppercase tracking-wider shadow-lg shadow-cyan-500/40">
                    Más popular
                  </div>
                </div>
              )}

              {/* Card */}
              <div
                class={`relative h-full p-8 rounded-[calc(1.5rem-1px)] flex flex-col overflow-hidden transition-colors duration-500 ${
                  plan.isPrimary
                    ? "bg-slate-900"
                    : "bg-slate-900/80 backdrop-blur-xl group-hover:bg-slate-900"
                }`}
              >
                {/* Inner top glow for featured / personalized */}
                {(plan.isPrimary || plan.isPersonalized) && (
                  <div
                    class={`absolute -top-px left-1/2 -translate-x-1/2 w-3/4 h-px ${
                      plan.isPrimary
                        ? "bg-gradient-to-r from-transparent via-cyan-300/70 to-transparent"
                        : "bg-gradient-to-r from-transparent via-violet-300/60 to-transparent"
                    }`}
                  />
                )}

                {/* Plan Header */}
                <div class="text-center mb-8">
                  <h3
                    class={`font-display font-semibold mb-4 break-words leading-tight ${
                      plan.isPersonalized
                        ? "text-2xl text-transparent bg-clip-text bg-gradient-to-r from-violet-200 to-indigo-200"
                        : plan.isPrimary
                          ? "text-xl text-transparent bg-clip-text bg-gradient-to-r from-cyan-100 to-cyan-300"
                          : "text-xl text-white"
                    }`}
                  >
                    {plan.name}
                  </h3>
                  <p class="text-slate-400 text-sm mt-3 leading-relaxed">
                    {plan.description}
                  </p>
                </div>

                {/* Features List */}
                <ul class="space-y-3.5 mb-8 flex-grow">
                  {plan.features.map((feature) => (
                    <li class="flex items-start gap-3">
                      <span
                        class={`mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full ${
                          plan.isPersonalized
                            ? "bg-violet-500/15 text-violet-300"
                            : "bg-cyan-500/15 text-cyan-300"
                        }`}
                      >
                        <Icon name="lucide:check" size={12} />
                      </span>
                      <span class="text-slate-300 text-sm leading-relaxed">
                        {feature}
                      </span>
                    </li>
                  ))}
                </ul>

                {/* CTA Button */}
                <a
                  href={plan.ctaHref}
                  target={
                    plan.ctaHref.startsWith("http") ? "_blank" : undefined
                  }
                  rel={
                    plan.ctaHref.startsWith("http")
                      ? "noopener noreferrer"
                      : undefined
                  }
                  class={`w-full py-3.5 px-6 rounded-full text-center font-semibold text-sm transition-all duration-300 flex items-center justify-center gap-2 ${
                    plan.isPrimary
                      ? "bg-gradient-to-r from-cyan-400 to-cyan-500 text-slate-950 hover:shadow-lg hover:shadow-cyan-500/40 hover:brightness-110"
                      : plan.isPersonalized
                        ? "bg-gradient-to-r from-violet-500/90 to-indigo-500/90 text-white hover:shadow-lg hover:shadow-violet-500/30 hover:brightness-110"
                        : "bg-white/5 text-white border border-white/15 hover:bg-white/10 hover:border-white/30"
                  }`}
                >
                  {plan.ctaText}
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
