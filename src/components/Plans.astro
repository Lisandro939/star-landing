---
import { Icon } from "astro-icon/components";

interface Plan {
  name: string;
  description: string;
  features: string[];
  ctaText: string;
  ctaHref: string;
  isPopular?: boolean;
  isPrimary?: boolean;
  isPersonalized?: boolean;
}

const plans: Plan[] = [
  {
    name: "PÁGINA WEB",
    description: "Ideal para emprendedores y startups",
    features: [
      "Diseño moderno y adaptable",
      "Secciones personalizadas",
      "Formulario de contacto",
      "Optimización SEO avanzada",
      "Entrega en 48 horas",
    ],
    ctaText: "Comenzar",
    ctaHref:
      "https://wa.me/5492615990250?text=¡Hola!%20Me%20gustaría%20saber%20más%20sobre%20el%20desarrollo%20de%20una%20página%20web.",
    isPopular: true,
    isPrimary: true,
    isPersonalized: false,
  },
  {
    name: "SISTEMA DE GESTIÓN",
    description: "Para negocios en crecimiento",
    features: [
      "Control de inventario y movimientos de stock",
      "Alertas de productos con stock bajo",
      "Registro de ventas, ingresos y gastos",
      "Reportes de ventas, stock y rendimiento",
      "Generación de presupuestos, comprobantes y documentos",
      "Mantenimiento, actualizaciones y soporte técnico",
    ],
    ctaText: "Comenzar",
    ctaHref:
      "https://wa.me/5492615990250?text=¡Hola!%20Me%20interesaría%20obtener%20más%20información%20sobre%20un%20sistema%20de%20gestión.",
    isPopular: false,
    isPrimary: false,
    isPersonalized: false,
  },
  {
    name: "E-COMMERCE",
    description: "Vendé tus productos las 24 horas, desde cualquier lugar",
    features: [
      "Catálogo de productos y categorías",
      "Carrito de compras y gestión de pedidos",
      "Integración con Mercado Pago",
      "Control de stock en tiempo real",
      "Gestión de clientes y ventas",
      "Cupones, promociones y descuentos",
      "Panel autogestionable",
      "Reportes de ventas y productos más vendidos",
      "Diseño adaptable a celulares y computadoras",
      "Mantenimiento y soporte técnico",
    ],
    ctaText: "Comenzar",
    ctaHref:
      "https://wa.me/5492615990250?text=¡Hola!%20Quiero%20consultar%20sobre%20el%20desarrollo%20de%20un%20e-commerce.",
    isPopular: false,
    isPrimary: false,
    isPersonalized: false,
  },
  {
    name: "SISTEMA PERSONALIZADO",
    description: "Nos adaptamos a tu necesidad",
    features: [
      "E-commerce",
      "Turneros y reservas automatizadas",
      "Plataformas educativas",
      "Generadores de documentos",
      "Cotizadores automáticos",
      "Portales de autogestión de clientes",
    ],
    ctaText: "Quiero un presupuesto",
    ctaHref:
      "https://wa.me/5492615990250?text=¡Hola!%20Me%20gustaría%20cotizar%20un%20sistema%20personalizado%20a%20medida.",
    isPopular: false,
    isPrimary: false,
    isPersonalized: true,
  },
];
---

<section class="py-24 bg-slate-950 relative" id="planes">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div
      class="absolute top-[20%] right-[-5%] w-[35%] h-[50%] bg-cyan-900/10 rounded-full blur-[120px]"
    >
    </div>
    <div
      class="absolute bottom-[10%] left-[-10%] w-[30%] h-[40%] bg-indigo-900/10 rounded-full blur-[100px]"
    >
    </div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-7xl mx-auto">
      <!-- Header -->
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2
          class="text-4xl md:text-5xl font-normal font-display text-white mb-6 tracking-tight"
        >
          Planes que <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-200 to-indigo-200"
            >escalan contigo</span
          >
        </h2>
        <p class="text-lg text-slate-400">
          Elige el plan perfecto para tu negocio. Sin costos ocultos.
        </p>
      </div>

      <!-- Plans Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          plans.map((plan) => (
            <div
              class={`relative group rounded-2xl transition-all duration-500`}
            >
              {/* Popular Badge */}
              {plan.isPopular && (
                <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-20">
                  <div class="px-4 py-1.5 rounded-full bg-cyan-500 text-white text-xs font-bold uppercase tracking-wider shadow-lg shadow-cyan-500/30">
                    Más popular
                  </div>
                </div>
              )}

              {/* Card */}
              <div
                class={`h-full p-8 rounded-2xl border backdrop-blur-sm transition-all duration-500 flex flex-col ${
                  plan.isPrimary
                    ? "bg-slate-900/80 border-cyan-500/30 shadow-xl shadow-cyan-500/5"
                    : "bg-slate-900/40 border-white/5 hover:border-white/10"
                }`}
              >
                {/* Plan Header */}
                <div class="text-center mb-8">
                  <h3
                    class={` font-display font-medium mb-4 ${plan.isPersonalized ? "text-3xl" : "text-xl"}`}
                  >
                    {plan.name}
                  </h3>
                  <p class="text-slate-400 text-sm mt-3">{plan.description}</p>
                </div>

                {/* Features List */}
                <ul class="space-y-4 mb-8 flex-grow">
                  {plan.features.map((feature) => (
                    <li class="flex items-start gap-3">
                      <div class="mt-0.5 flex-shrink-0">
                        <Icon
                          name="lucide:check"
                          class="text-cyan-400"
                          size={18}
                        />
                      </div>
                      <span class="text-slate-300 text-sm">{feature}</span>
                    </li>
                  ))}
                </ul>

                {/* CTA Button */}
                <a
                  href={plan.ctaHref}
                  target={
                    plan.ctaHref.startsWith("http") ? "_blank" : undefined
                  }
                  rel={
                    plan.ctaHref.startsWith("http")
                      ? "noopener noreferrer"
                      : undefined
                  }
                  class={`w-full py-3.5 px-6 rounded-full text-center font-medium text-sm transition-all duration-300 flex items-center justify-center gap-2 ${
                    plan.isPrimary
                      ? "bg-cyan-500 text-white hover:bg-cyan-400 shadow-lg"
                      : "bg-white/5 text-white border border-white/10 hover:bg-white/10 hover:border-white/20"
                  }`}
                >
                  {plan.ctaText}
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
