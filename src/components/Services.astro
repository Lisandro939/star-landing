---
import efectosMendozaPc from '../assets/companies-examples/efectos-mendoza-pc.png';
import efectosMendozaMobile from '../assets/companies-examples/efectos-mendoza-mobile.png';
import esteticaAmapolaPc from '../assets/companies-examples/estetica-amapola-pc.png';
import esteticaAmapolaMobile from '../assets/companies-examples/estetica-amapola-mobile.png';
import puntoLunchPc from '../assets/companies-examples/punto-lunch-pc.png';
import puntoLunchMobile from '../assets/companies-examples/punto-lunch-mobile.png';
import deliveriesEnLavallePc from '../assets/companies-examples/deliveries-en-lavalle-pc.png';
import deliveriesEnLavalleMobile from '../assets/companies-examples/deliveries-en-lavalle-mobile.png';
import elBosquePc from '../assets/companies-examples/el-bosque-pc.png';
import elBosqueMobile from '../assets/companies-examples/el-bosque-mobile.png';

interface Project {
  id: number;
  type: 'vertical' | 'horizontal';
  image?: ImageMetadata;
  title?: string;
  url?: string;
}

const projects: Project[] = [
  { id: 1, type: 'horizontal', image: deliveriesEnLavallePc, title: 'Deliveries en Lavalle' },
  { id: 2, type: 'horizontal', image: efectosMendozaPc, title: 'Efectos Mendoza', url: 'https://mendoza-efectos.vercel.app/' },
  { id: 3, type: 'horizontal', image: esteticaAmapolaPc, title: 'Estética Amapola' },
  { id: 4, type: 'horizontal', image: puntoLunchPc, title: 'Punto Lunch' },
  { id: 5, type: 'horizontal', image: elBosquePc, title: 'El Bosque' },
  { id: 6, type: 'vertical', image: deliveriesEnLavalleMobile, title: 'Deliveries en Lavalle' },
  { id: 7, type: 'vertical', image: efectosMendozaMobile, title: 'Efectos Mendoza' },
  { id: 8, type: 'vertical', image: esteticaAmapolaMobile, title: 'Estética Amapola' },
  { id: 9, type: 'vertical', image: puntoLunchMobile, title: 'Punto Lunch' },
  { id: 10, type: 'vertical', image: elBosqueMobile, title: 'El Bosque' },
];

const horizontal = projects.filter(p => p.type === 'horizontal');
const vertical = projects.filter(p => p.type === 'vertical');
const carouselSlides = horizontal.map((h, i) => ({ pc: h, mobile: vertical[i] }));
---

<section class="py-24 bg-slate-950 relative" id="servicios">
  <!-- Decorative background elements -->
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-cyan-900/10 rounded-full blur-[100px]"></div>
  </div>

  <div class="relative z-10 w-full">
    <div class="container mx-auto px-4 md:px-6 mb-12">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-normal font-display text-white mb-6 tracking-tight">
          Nuestros <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-200 to-indigo-200">Proyectos</span>
        </h2>
        <p class="text-lg text-slate-400">
          Una colección de experiencias digitales diseñadas para impactar y escalar.
        </p>
      </div>
    </div>

    <!-- Masonry Grid Wrapper with Height Constraint -->
    <div class="w-full relative">
        
        <!-- Desktop Grid -->
        <div class="hidden md:grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3 px-2">
          {projects.map((project) => {
            const Wrapper = project.url ? 'a' : 'div';
            const wrapperProps = project.url
              ? { href: project.url, target: '_blank', rel: 'noopener noreferrer' }
              : {};

            return (
            <Wrapper {...wrapperProps} class={`${project.image ? 'group relative rounded-2xl overflow-hidden border border-white/5 bg-white/5 backdrop-blur-sm transition-all duration-500 hover:border-cyan-500/30 hover:z-10' : 'rounded-2xl overflow-hidden'}`}>
              
              <!-- Aspect Ratio Container -->
              <div class={`relative w-full ${project.type === 'vertical' ? 'aspect-[10/20]' : 'aspect-video'} flex flex-col items-center justify-center p-4 text-center ${project.image ? 'bg-slate-900/50' : ''}`}>
                
                {project.image ? (
                  <img src={project.image.src} alt={project.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                ) : null}
                
                {project.image && (
                  <!-- Hover Overlay -->
                  <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-4">
                       <div class="transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                           <span class="inline-block px-2 py-0.5 rounded-full bg-cyan-500/20 text-cyan-200 text-[10px] font-bold uppercase tracking-wider mb-1 border border-cyan-500/20 backdrop-blur-md">
                               {project.type === 'horizontal' ? 'Web' : 'Web'}
                           </span>
                       </div>
                  </div>
                )}

              </div>

            </Wrapper>
            );
          })}
        </div>

        <!-- Mobile Carousel -->
        <div class="md:hidden relative" id="carousel">
          <!-- Arrow Left -->
          <button id="carousel-prev" class="absolute left-1 top-1/2 -translate-y-1/2 z-10 w-9 h-9 rounded-full bg-white/10 backdrop-blur-md border border-white/10 flex items-center justify-center text-white/70 hover:bg-white/20 hover:text-white transition-all" aria-label="Anterior">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
          </button>

          <!-- Arrow Right -->
          <button id="carousel-next" class="absolute right-1 top-1/2 -translate-y-1/2 z-10 w-9 h-9 rounded-full bg-white/10 backdrop-blur-md border border-white/10 flex items-center justify-center text-white/70 hover:bg-white/20 hover:text-white transition-all" aria-label="Siguiente">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </button>

          <div class="overflow-hidden rounded-2xl mx-6">
            <div class="flex transition-transform duration-500 ease-out" id="carousel-track">
              {carouselSlides.map((slide) => (
                <div class="w-full flex-shrink-0 px-2">
                  <div class="flex flex-col gap-3">
                    {[slide.pc, slide.mobile].map((project) => {
                      const Wrapper = project.url ? 'a' : 'div';
                      const wrapperProps = project.url
                        ? { href: project.url, target: '_blank', rel: 'noopener noreferrer' }
                        : {};

                      return (
                      <Wrapper {...wrapperProps} class="group relative rounded-2xl overflow-hidden border border-white/5 bg-white/5 backdrop-blur-sm">
                        <div class={`relative w-full ${project.type === 'vertical' ? 'aspect-[10/20]' : 'aspect-video'} bg-slate-900/50`}>
                          <img src={project.image?.src} alt={project.title} class="absolute inset-0 w-full h-full object-cover" />
                          <div class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-slate-950/80 to-transparent p-3">
                            <span class="inline-block px-2 py-0.5 rounded-full bg-cyan-500/20 text-cyan-200 text-[10px] font-bold uppercase tracking-wider border border-cyan-500/20 backdrop-blur-md">
                              {project.type === 'horizontal' ? 'Web' : 'Mobile'}
                            </span>
                          </div>
                        </div>
                      </Wrapper>
                      );
                    })}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Dots -->
          <div class="flex justify-center gap-2 mt-4" id="carousel-dots">
            {carouselSlides.map((_, i) => (
              <button class={`w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? 'bg-cyan-400 w-6' : 'bg-white/20'}`} data-dot={i} aria-label={`Slide ${i + 1}`} />
            ))}
          </div>
        </div>

    </div>
  </div>
</section>

<script>
  const track = document.getElementById('carousel-track')!;
  const dots = document.querySelectorAll('[data-dot]');
  const prevBtn = document.getElementById('carousel-prev')!;
  const nextBtn = document.getElementById('carousel-next')!;
  const totalSlides = dots.length;
  let current = 0;
  let startX = 0;
  let isDragging = false;

  function goTo(index: number) {
    current = ((index % totalSlides) + totalSlides) % totalSlides;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((dot, i) => {
      (dot as HTMLElement).className = `w-2 h-2 rounded-full transition-all duration-300 ${i === current ? 'bg-cyan-400 w-6' : 'bg-white/20'}`;
    });
  }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => goTo(i));
  });

  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));

  track.addEventListener('touchstart', (e) => {
    startX = (e as TouchEvent).touches[0].clientX;
    isDragging = true;
    (track as HTMLElement).style.transition = 'none';
  });

  track.addEventListener('touchmove', (e) => {
    if (!isDragging) return;
    const diff = (e as TouchEvent).touches[0].clientX - startX;
    const offset = -(current * track.clientWidth) + diff;
    (track as HTMLElement).style.transform = `translateX(${offset}px)`;
  });

  track.addEventListener('touchend', (e) => {
    if (!isDragging) return;
    isDragging = false;
    (track as HTMLElement).style.transition = '';
    const diff = (e as TouchEvent).changedTouches[0].clientX - startX;
    if (Math.abs(diff) > 50) {
      goTo(current + (diff < 0 ? 1 : -1));
    } else {
      goTo(current);
    }
  });
</script>
