---
import { Icon } from 'astro-icon/components';
import efectosMendozaPc from '../assets/companies-examples/efectos-mendoza-pc.png';
import efectosMendozaMobile from '../assets/companies-examples/efectos-mendoza-mobile.png';
import esteticaAmapolaPc from '../assets/companies-examples/estetica-amapola-pc.png';
import esteticaAmapolaMobile from '../assets/companies-examples/estetica-amapola-mobile.png';
import puntoLunchPc from '../assets/companies-examples/punto-lunch-pc.png';
import puntoLunchMobile from '../assets/companies-examples/punto-lunch-mobile.png';
import deliveriesEnLavallePc from '../assets/companies-examples/deliveries-en-lavalle-pc.png';
import deliveriesEnLavalleMobile from '../assets/companies-examples/deliveries-en-lavalle-mobile.png';
import elBosquePc from '../assets/companies-examples/el-bosque-pc.png';
import elBosqueMobile from '../assets/companies-examples/el-bosque-mobile.png';
import brenatPc from '../assets/companies-examples/brenat-pc.png';
import brenatMobile from '../assets/companies-examples/brenat-mobile.png';
import dmleonPc from '../assets/companies-examples/dmleon-pc.png';
import dmleonMobile from '../assets/companies-examples/dmleon-mobile.png';

interface Project {
  id: number;
  title: string;
  url: string;
  imagePc: ImageMetadata;
  imageMobile: ImageMetadata;
}

const projects: Project[] = [
  { id: 1, title: 'Deliveries en Lavalle', url: 'https://www.deliveriesenlavalle.com.ar/', imagePc: deliveriesEnLavallePc, imageMobile: deliveriesEnLavalleMobile },
  { id: 2, title: 'Efectos Mendoza', url: 'https://mendoza-efectos.vercel.app/', imagePc: efectosMendozaPc, imageMobile: efectosMendozaMobile },
  { id: 3, title: 'Estética Amapola', url: 'https://amapola-estetica.vercel.app/', imagePc: esteticaAmapolaPc, imageMobile: esteticaAmapolaMobile },
  { id: 4, title: 'Punto Lunch', url: 'https://punto-lunch.vercel.app/', imagePc: puntoLunchPc, imageMobile: puntoLunchMobile },
  { id: 5, title: 'El Bosque', url: 'https://www.elbosquesunset.com/', imagePc: elBosquePc, imageMobile: elBosqueMobile },
  { id: 6, title: 'Brenat', url: 'https://www.brenat.com.ar/', imagePc: brenatPc, imageMobile: brenatMobile },
  { id: 7, title: 'DM León', url: 'https://www.dmleon.com.ar/', imagePc: dmleonPc, imageMobile: dmleonMobile },
];

// Slides cloned at both edges for seamless infinite loop: [last, ...all, first]
const slides = [projects[projects.length - 1], ...projects, projects[0]];
---

<section class="py-24 bg-slate-950 relative" id="servicios">
  <!-- Decorative background elements -->
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-cyan-900/10 rounded-full blur-[100px]"></div>
  </div>

  <div class="relative z-10 w-full">
    <div class="container mx-auto px-4 md:px-6 mb-12">
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-block mb-5 px-4 py-1.5 rounded-full border border-white/10 bg-white/5 text-xs font-medium uppercase tracking-[0.2em] text-cyan-300/90">
          Portfolio
        </span>
        <h2 class="text-4xl md:text-5xl font-normal font-display text-white mb-6 tracking-tight">
          Nuestros <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-200 to-indigo-200">Proyectos</span>
        </h2>
        <p class="text-lg text-slate-400">
          Una colección de experiencias digitales diseñadas para impactar y escalar.
        </p>
      </div>
    </div>

    <!-- Unified Infinite Carousel -->
    <div class="container mx-auto px-4 md:px-6">
      <div class="relative max-w-7xl mx-auto" id="carousel">
        <!-- Arrow Left -->
        <button
          id="carousel-prev"
          class="cursor-pointer absolute left-1 sm:left-2 md:-left-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 md:w-12 md:h-12 rounded-full bg-white/10 backdrop-blur-md border border-white/10 flex items-center justify-center text-white/70 hover:bg-cyan-500/20 hover:border-cyan-500/30 hover:text-white transition-all"
          aria-label="Proyecto anterior"
        >
          <Icon name="lucide:chevron-left" class="w-5 h-5 md:w-6 md:h-6" />
        </button>

        <!-- Arrow Right -->
        <button
          id="carousel-next"
          class="cursor-pointer absolute right-1 sm:right-2 md:-right-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 md:w-12 md:h-12 rounded-full bg-white/10 backdrop-blur-md border border-white/10 flex items-center justify-center text-white/70 hover:bg-cyan-500/20 hover:border-cyan-500/30 hover:text-white transition-all"
          aria-label="Proyecto siguiente"
        >
          <Icon name="lucide:chevron-right" class="w-5 h-5 md:w-6 md:h-6" />
        </button>

        <div class="overflow-hidden rounded-2xl mx-8 md:mx-10">
          <div class="flex" id="carousel-track">
            {slides.map((project) => (
              <div class="w-full flex-shrink-0 px-2 md:px-4">
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-project-link
                  class="group relative block w-full max-w-[280px] md:max-w-none mx-auto rounded-2xl overflow-hidden border border-white/10 bg-white/5 backdrop-blur-sm transition-all duration-500 hover:border-cyan-400/40 hover:shadow-2xl hover:shadow-cyan-500/10"
                >
                  <!-- Mobile: tall vertical phone capture as protagonist. Desktop (md+): PC mockup aspect-video. -->
                  <div class="relative w-full aspect-[10/20] md:aspect-video bg-slate-900/50">
                    <!-- Mobile-only protagonist: vertical phone capture, full bleed -->
                    <img
                      src={project.imageMobile.src}
                      alt={`${project.title} — versión móvil`}
                      loading="lazy"
                      draggable="false"
                      class="md:hidden absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 select-none"
                    />

                    <!-- Desktop-only PC capture -->
                    <img
                      src={project.imagePc.src}
                      alt={`${project.title} — versión escritorio`}
                      loading="lazy"
                      draggable="false"
                      class="hidden md:block absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 select-none"
                    />

                    <!-- Desktop-only: mobile capture showcase overlay, bottom-right corner -->
                    <div class="hidden md:block absolute bottom-3 right-3 sm:bottom-4 sm:right-4 w-[30%] max-w-[170px] aspect-[10/20] rounded-xl overflow-hidden border border-white/10 shadow-2xl shadow-black/50 bg-slate-900 transition-transform duration-500 group-hover:-translate-y-1">
                      <img
                        src={project.imageMobile.src}
                        alt={`${project.title} — versión móvil`}
                        loading="lazy"
                        draggable="false"
                        class="absolute inset-0 w-full h-full object-cover select-none"
                      />
                    </div>

                    <!-- Hover overlay: title + link cue -->
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-4 md:p-6 pointer-events-none">
                      <div class="transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                        <span class="inline-block px-2 py-0.5 rounded-full bg-cyan-500/20 text-cyan-200 text-[10px] font-bold uppercase tracking-wider mb-2 border border-cyan-500/20 backdrop-blur-md">
                          Web
                        </span>
                        <div class="flex items-center gap-2">
                          <h3 class="text-white text-lg md:text-xl font-medium">{project.title}</h3>
                          <Icon name="lucide:arrow-up-right" class="w-4 h-4 text-cyan-200" />
                        </div>
                      </div>
                    </div>
                  </div>
                </a>
              </div>
            ))}
          </div>
        </div>

        <!-- Dots -->
        <div class="flex justify-center flex-wrap gap-2 mt-6" id="carousel-dots">
          {projects.map((_, i) => (
            <button
              class={`h-2 rounded-full transition-all duration-300 ${i === 0 ? 'bg-cyan-400 w-6' : 'bg-white/20 w-2 hover:bg-white/40'}`}
              data-dot={i}
              aria-label={`Ir al proyecto ${i + 1}`}
            />
          ))}
        </div>
      </div>
    </div>

    <!-- Closing CTA: invitation to grow with the team -->
    <div class="container mx-auto px-4 md:px-6 mt-20 md:mt-28">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-normal font-display text-white tracking-tight leading-tight">
          ¿Tu proyecto es el <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-200 to-indigo-200">próximo</span>?<br class="hidden sm:block" /> Crecé con nosotros.
        </h2>
        <p class="text-lg text-slate-400 mt-6">
          Sumate al equipo que convierte ideas en experiencias digitales que escalan.
        </p>
        <div class="mt-10 flex justify-center">
          <a
            href="#contacto"
            class="group inline-flex items-center gap-3 px-8 py-4 rounded-full bg-gradient-to-r from-cyan-500 to-indigo-500 text-white font-bold text-base md:text-lg hover:from-cyan-400 hover:to-indigo-400 hover:scale-105 hover:shadow-lg hover:shadow-cyan-500/25 transition-all duration-300"
          >
            Hablemos de tu proyecto
            <Icon name="lucide:arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('carousel-track')!;
  const dots = document.querySelectorAll<HTMLElement>('[data-dot]');
  const prevBtn = document.getElementById('carousel-prev')!;
  const nextBtn = document.getElementById('carousel-next')!;
  const links = track.querySelectorAll<HTMLElement>('[data-project-link]');

  const realCount = dots.length; // number of actual projects
  // Track layout: [clone(last), 0, 1, ..., realCount-1, clone(first)]
  // Start on index 1 (first real project).
  let pos = 1;
  const TRANSITION = 'transform 500ms ease-out';

  function applyTransform(animate: boolean) {
    track.style.transition = animate ? TRANSITION : 'none';
    track.style.transform = `translateX(-${pos * 100}%)`;
  }

  function updateDots() {
    // Map carousel position back to a real project index.
    let real = pos - 1;
    if (real < 0) real = realCount - 1;
    if (real >= realCount) real = 0;
    dots.forEach((dot, i) => {
      dot.className = `h-2 rounded-full transition-all duration-300 ${
        i === real ? 'bg-cyan-400 w-6' : 'bg-white/20 w-2 hover:bg-white/40'
      }`;
    });
  }

  function go(delta: number) {
    pos += delta;
    applyTransform(true);
    updateDots();
  }

  function goToReal(realIndex: number) {
    pos = realIndex + 1;
    applyTransform(true);
    updateDots();
  }

  // Seamless wrap: when landing on a clone, jump instantly to the twin.
  track.addEventListener('transitionend', () => {
    if (pos === 0) {
      pos = realCount;
      applyTransform(false);
    } else if (pos === realCount + 1) {
      pos = 1;
      applyTransform(false);
    }
  });

  prevBtn.addEventListener('click', () => go(-1));
  nextBtn.addEventListener('click', () => go(1));
  dots.forEach((dot, i) => dot.addEventListener('click', () => goToReal(i)));

  // Touch / pointer drag with threshold + click guard.
  let startX = 0;
  let currentX = 0;
  let dragging = false;
  let moved = false;

  function onStart(clientX: number) {
    startX = clientX;
    currentX = clientX;
    dragging = true;
    moved = false;
    track.style.transition = 'none';
  }

  function onMove(clientX: number) {
    if (!dragging) return;
    currentX = clientX;
    const diff = currentX - startX;
    if (Math.abs(diff) > 5) moved = true;
    const offsetPct = (diff / track.clientWidth) * 100;
    track.style.transform = `translateX(calc(-${pos * 100}% + ${offsetPct}%))`;
  }

  function onEnd() {
    if (!dragging) return;
    dragging = false;
    const diff = currentX - startX;
    if (Math.abs(diff) > 50) {
      go(diff < 0 ? 1 : -1);
    } else {
      applyTransform(true);
    }
  }

  // Touch events
  track.addEventListener('touchstart', (e) => onStart(e.touches[0].clientX), { passive: true });
  track.addEventListener('touchmove', (e) => onMove(e.touches[0].clientX), { passive: true });
  track.addEventListener('touchend', onEnd);

  // Mouse drag (desktop)
  track.addEventListener('mousedown', (e) => {
    e.preventDefault();
    onStart(e.clientX);
  });
  window.addEventListener('mousemove', (e) => onMove(e.clientX));
  window.addEventListener('mouseup', onEnd);

  // Prevent a drag from triggering navigation.
  links.forEach((link) => {
    link.addEventListener('click', (e) => {
      if (moved) {
        e.preventDefault();
        moved = false;
      }
    });
  });

  // Initialize position without animation.
  applyTransform(false);
  updateDots();
</script>
